  30:Core/Src/mcp3208.c **** /* ===========================================================================
  31:Core/Src/mcp3208.c ****  * MCP3208_ReadRaw
  32:Core/Src/mcp3208.c ****  * ===========================================================================
  33:Core/Src/mcp3208.c ****  * Führt einen vollständigen 3-Byte SPI-Transfer durch und gibt den 12-bit
  34:Core/Src/mcp3208.c ****  * Rohwert zurück.
  35:Core/Src/mcp3208.c ****  *
  36:Core/Src/mcp3208.c ****  * SPI-Protokoll im Detail (Kanal 0 als Beispiel):
  37:Core/Src/mcp3208.c ****  *
  38:Core/Src/mcp3208.c ****  *   tx[0] = 0x06 | (0 >> 2) = 0x06 = 0b00000110
  39:Core/Src/mcp3208.c ****  *           Bit1 = START-Bit (immer 1)
  40:Core/Src/mcp3208.c ****  *           Bit0 = SGL/DIFF  (1 = Single-Ended)
  41:Core/Src/mcp3208.c ****  *           D2   = MSB des Kanals (für Kanal 0..3 = 0, für 4..7 = 1)
  42:Core/Src/mcp3208.c ****  *
  43:Core/Src/mcp3208.c ****  *   tx[1] = (0 & 0x03) << 6 = 0x00 = 0b00000000
ARM GAS  C:\Users\ChipTec\AppData\Local\Temp\ccdjoKgV.s 			page 3


  44:Core/Src/mcp3208.c ****  *           D1, D0 = restliche Kanal-Bits
  45:Core/Src/mcp3208.c ****  *
  46:Core/Src/mcp3208.c ****  *   tx[2] = 0x00 (Dummy-Byte, taktet die Antwort-Bits heraus)
  47:Core/Src/mcp3208.c ****  *
  48:Core/Src/mcp3208.c ****  * Antwort in rx[]:
  49:Core/Src/mcp3208.c ****  *   rx[0]: Dummy (MCP3208 noch nicht bereit)
  50:Core/Src/mcp3208.c ****  *   rx[1]: Null-Bit + 4 obere Datenbits (B11..B8)
  51:Core/Src/mcp3208.c ****  *   rx[2]: 8 untere Datenbits (B7..B0)
  52:Core/Src/mcp3208.c ****  *
  53:Core/Src/mcp3208.c ****  * Ergebnis: ((rx[1] & 0x0F) << 8) | rx[2]
  54:Core/Src/mcp3208.c ****  * =========================================================================== */
  55:Core/Src/mcp3208.c **** uint16_t MCP3208_ReadRaw(uint8_t channel)
