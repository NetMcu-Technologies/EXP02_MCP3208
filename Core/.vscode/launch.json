{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex-Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/your_project.elf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32l4x.cfg"
            ],
            "runToEntryPoint": "main",
            "preLaunchTask": "Build (make all)",
            "svdFile": "${workspaceFolder}/STM32L4x6.svd",
            "device": "STM32L476RG",
            "showDevDebugOutput": "raw"
        }
    ]
}